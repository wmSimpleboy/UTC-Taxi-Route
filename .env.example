# Copy to .env and fill in real values. Never commit .env.

# Flask
FLASK_SECRET_KEY=generate-a-long-random-string-here
# Set to 1 only for local development (never in production)
FLASK_DEBUG=0
# Web UI port
FLASK_PORT=4017
# Listen address (default 127.0.0.1; use 0.0.0.0 for Docker)
# FLASK_HOST=0.0.0.0

# Login
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# OSRM (host port where osrm-routed listens, often 5000 → http://localhost:5000)
OSRM_BASE_URL=http://localhost:5000

# Route split: if a single-car route is >= SPLIT_MIN_ROUTE_KM km,
# try splitting into 2 cars when the extra cost is <= SPLIT_MAX_EXTRA_COST_UZS.
SPLIT_MIN_ROUTE_KM=25
SPLIT_MAX_EXTRA_COST_UZS=10000

# Google Maps — only needed for geocoding helpers in data_tools
GOOGLE_MAPS_API_KEY=

# Telegram bot notifications (for route confirmations + reports)
# TELEGRAM_CHAT_IDS: comma-separated chat ids for regular users (basic route info)
# TELEGRAM_SUPERUSER_CHAT_IDS: comma-separated chat ids for superusers (detailed costs + /otchet command)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_SUPERUSER_CHAT_IDS=
