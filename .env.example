# Copy to .env and fill in real values. Never commit .env.

# Flask
FLASK_SECRET_KEY=generate-a-long-random-string-here
# Set to 1 only for local development (never in production)
FLASK_DEBUG=0
# Web UI port (use another port than OSRM, e.g. 5002)
FLASK_PORT=5002

# Login
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# OSRM (host port where osrm-routed listens, often 5000 → http://localhost:5000)
OSRM_BASE_URL=http://localhost:5000

# Google Maps — only needed for geocoding helpers in data_tools
GOOGLE_MAPS_API_KEY=
