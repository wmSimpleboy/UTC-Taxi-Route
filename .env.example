# Copy to .env and fill in real values. Never commit .env.

# Flask
FLASK_SECRET_KEY=generate-a-long-random-string-here
# Set to 1 only for local development (never in production)
FLASK_DEBUG=0
# Web UI port (OSRM should use a different port, e.g. 5001)
FLASK_PORT=5002

# Login
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# OSRM (must match docker -p host:5000, e.g. http://localhost:5001)
OSRM_BASE_URL=http://localhost:5001

# Google Maps — only needed for geocoding helpers in data_tools
GOOGLE_MAPS_API_KEY=
